// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  name      String?
  password  String
  role      Role     @default(RECEPTIONIST)
  modules   String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Audit trail of actions taken in the app. mrNumber/userName are snapshotted
// so the log stays searchable and readable even if records change.
model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  mrNumber    String?
  userId      String?
  userName    String?
  createdAt   DateTime @default(now())

  @@index([mrNumber])
  @@index([createdAt])
  @@map("activity_logs")
}

// A registered patient. `serial` is a DB sequence used to derive the MR
// number (e.g. serial 1 -> "MR-20001"); `mrNumber` is then stored for search.
model Patient {
  id        String   @id @default(cuid())
  serial    Int      @unique @default(autoincrement())
  mrNumber  String?  @unique
  name      String
  age       Int
  gender    Gender
  mobile    String?
  cnic      String?
  doctorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        Doctor?               @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  tests         PatientTest[]
  consultations PatientConsultation[]
  payments      Payment[]

  @@map("patients")
}

// Master list of consultation fees (name + rate), managed manually.
model ConsultationFee {
  id        String   @id @default(cuid())
  name      String   @unique
  rate      Int // whole rupees
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applied PatientConsultation[]

  @@map("consultation_fees")
}

// A consultation fee applied to a patient. name/rate are snapshotted so the
// record stays accurate even if the fee catalog changes.
model PatientConsultation {
  id        String   @id @default(cuid())
  patientId String
  feeId     String?
  name      String
  rate      Int
  createdAt DateTime @default(now())

  patient Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fee     ConsultationFee? @relation(fields: [feeId], references: [id], onDelete: SetNull)

  @@map("patient_consultations")
}

// Master list of test types and their rates (the "Test Catalog").
model TestCatalog {
  id        String   @id @default(cuid())
  name      String   @unique
  rate      Int // whole rupees
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders PatientTest[]

  @@map("test_catalog")
}

// A test ordered for a specific patient. testName/rate are snapshotted at
// order time so the record stays accurate even if the catalog changes.
model PatientTest {
  id        String        @id @default(cuid())
  patientId String
  testId    String?
  testName  String
  rate      Int
  status    TestStatus    @default(PENDING)
  result    String?
  payment   PaymentStatus @default(UNPAID)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  patient Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  test    TestCatalog? @relation(fields: [testId], references: [id], onDelete: SetNull)

  @@map("patient_tests")
}

// A doctor / consultant. `fee` is the consultation fee in whole rupees.
model Doctor {
  id        String   @id @default(cuid())
  name      String
  mobile    String?
  fee       Int? // consultation fee in whole rupees
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients Patient[]

  @@map("doctors")
}

// An income payment collected from a patient (e.g. test charges paid at
// registration). Tracked as a plain collection — no payment method.
model Payment {
  id         String    @id @default(cuid())
  receiptNo  Int       @unique @default(autoincrement())
  patientId  String
  amount     Int
  refundedAt DateTime?
  createdAt  DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("payments")
}
